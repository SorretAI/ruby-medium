# =============================================================================
# TRENDING NEWS → MEDIUM PIPELINE
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# =============================================================================
# AI PROVIDERS (Summarization & Content Generation)
# =============================================================================

# OpenRouter (Primary AI - access to Mistral, Llama, Claude, etc.)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter Organization ID (optional, for team tracking)
OPENROUTER_ORG_ID=

# NVIDIA NIM (Secondary AI - Llama models, free tier)
# Get from: https://build.ngc.nvidia.com/
NVIDIA_API_KEY=

# Ollama Configuration (Local/self-hosted models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# =============================================================================
# DATABASE (PostgreSQL + pgvector)
# =============================================================================

# Full database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgres://user:password@localhost:5432/newsdb

# Individual connection params (for migration scripts)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=newsdb
DB_USER=user
DB_PASSWORD=password

# =============================================================================
# REDIS (Message Queue & Caching)
# =============================================================================

REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# DISCORD BOT (Human Review Interface)
# =============================================================================

# Discord Bot Token - from Discord Developer Portal
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Discord Application ID - from Discord Developer Portal
DISCORD_APP_ID=

# Discord Channel ID - where drafts are posted for review
DISCORD_CHANNEL_ID=

# Discord Server/Guild ID (optional, for admin commands)
DISCORD_GUILD_ID=

# =============================================================================
# MEDIUM API (Publishing)
# =============================================================================

# Medium API Token - from Medium Settings
# https://medium.com/settings/security
MEDIUM_API_KEY=

# Medium User ID - get from API after auth
MEDIUM_USER_ID=

# Medium Account Names for split testing
# Format: account_a,account_b (comma-separated)
MEDIUM_ACCOUNTS=

# =============================================================================
# MONITORING SOURCES (News APIs & Scrapers)
# =============================================================================

# Google Trends (via pytrends - no API key needed, rate limited)
# Optional: Google Custom Search API for additional data
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# NewsAPI (Top headlines)
# Get from: https://newsapi.org/
NEWSAPI_KEY=

# GDELT (Global events database - open access)
GDELT_API_KEY=

# Twitter/X API v2 (for scraper fallback)
# Get from: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Reddit API (PRAW)
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=my-trending-app/0.1.0 (by /u/yourusername)

# =============================================================================
# MAGICUI MCP (Frontend Landing Page)
# =============================================================================

# MagicUI MCP Server Configuration
# MagicUI API Key for component generation
MAGICUI_API_KEY=

# MagicUI MCP Server URL (if self-hosted)
MAGICUI_MCP_URL=http://localhost:8080

# Frontend display settings
MAGICUI_THEME=default
MAGICUI_DARK_MODE=true

# Landing page configuration
LANDING_PAGE_TITLE="Trending News AI"
LANDING_PAGE_SUBTITLE="AI-powered trending news analysis"
LANDING_PAGE_BRAND_COLOR=#FF4500

# =============================================================================
# LANDING PAGE (Frontend Configuration)
# =============================================================================

# Frontend server URL
FRONTend_URL=http://localhost:5173

# API endpoint for frontend
API_URL=http://localhost:3000

# SEO & Analytics
SITE_NAME="Trending News AI"
SITE_DESCRIPTION="Real-time trending news analysis with AI insights"
SITE_URL=https://yourdomain.com
GOOGLE_ANALYTICS_ID=
POSTHOG_API_KEY=

# =============================================================================
# VSL LANDING PAGE (Conversion Target)
# =============================================================================

# VSL (Video Sales Letter) Landing Page URL
VSL_LANDING_URL=https://your-vsl-page.com

# Tokenized Cinema Community URL
COMMUNITY_URL=https://your-community.com

# Consultation Booking URL
CONSULTATION_URL=https://calendly.com/your-link

# =============================================================================
# RUNTIME CONFIGURATION
# =============================================================================

# Application mode
NODE_ENV=development
PYTHONUNBUFFERED=1

# Logging level (debug, info, warning, error)
LOG_LEVEL=info

# Monitoring interval in minutes
MONITOR_INTERVAL_MINUTES=5

# Score threshold for topic processing (0-10)
SCORE_THRESHOLD=3.0

# =============================================================================
# RATE LIMITING & SCRAPING
# =============================================================================

# Twitter/X delay between requests (ms)
TWITTER_DELAY_MS=60000

# Reddit delay between requests (ms)
REDDIT_DELAY_MS=30000

# User-Agent for scraping
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Proxy for scraping (optional, for avoiding blocks)
SCRAPER_PROXY_URL=

# =============================================================================
# DOCKER / INFRASTRUCTURE
# =============================================================================

# Playwright browser data path
PLAYWRIGHT_BROWSERS_PATH=/workspace/browser-data

# Workspace directory (persistent storage)
WORKSPACE_DIR=/workspace

# Sentry error tracking (optional)
SENTRY_DSN=

# =============================================================================
# CFO / COST TRACKING
# =============================================================================

# Baseline hourly rate for cost calculations (USD)
BASELINE_HOURLY_RATE=7.00

# Default upsell/consultation value (USD)
DEFAULT_UPSELL_VALUE=75.00

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable components
ENABLE_TWITTER_SCRAPER=true
ENABLE_REDDIT_SCRAPER=true
ENABLE_GOOGLE_TRENDS=true
ENABLE_NEWSAPI=true
ENABLE_MEDIUM_PUBLISH=true
ENABLE_DISCORD_REVIEW=true
ENABLE_LANDING_PAGE=true

# =============================================================================
# DEVELOPMENT / DEBUGGING
# =============================================================================

# Enable debug mode for verbose logging
DEBUG=false

# Skip SSL verification (development only)
NODE_TLS_REJECT_UNAUTHORIZED=1

# Hot reload enabled
HOT_RELOAD=true

# =============================================================================
# END OF ENVIRONMENT CONFIGURATION
# =============================================================================
